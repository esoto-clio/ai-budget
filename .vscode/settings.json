{
  // Ruby and RuboCop settings
  "ruby.rubocop.executePath": "bundle exec",
  "ruby.rubocop.onSave": true,
  "ruby.rubocop.configFilePath": ".rubocop.yml",
  "ruby.format": "rubocop",
  "ruby.lint": {
    "rubocop": {
      "lint": true,
      "rails": true
    }
  },
  
  // Editor settings for Ruby files
  "[ruby]": {
    "editor.defaultFormatter": "misogi.ruby-rubocop",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.rulers": [120],
    "files.trimTrailingWhitespace": true
  },
  
  // ERB settings
  "[erb]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "files.trimTrailingWhitespace": true
  },
  
  // YAML settings (for config files)
  "[yaml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "files.trimTrailingWhitespace": true
  },
  
  // General editor settings
  "files.associations": {
    "*.rb": "ruby",
    "*.erb": "erb",
    "Gemfile": "ruby",
    "Rakefile": "ruby",
    "*.rake": "ruby",
    ".rubocop.yml": "yaml"
  },
  
  // Extension recommendations
  "extensions.recommendations": [
    "misogi.ruby-rubocop",
    "rebornix.ruby",
    "kaiwood.endwise",
    "bradlc.vscode-tailwindcss",
    "ms-vscode.vscode-json"
  ],
  
  // File exclude patterns
  "files.exclude": {
    "**/tmp": true,
    "**/log": true,
    "**/node_modules": true,
    "**/.git": true,
    "**/coverage": true
  },
  
  // Search exclude patterns
  "search.exclude": {
    "**/tmp": true,
    "**/log": true,
    "**/node_modules": true,
    "**/coverage": true,
    "**/vendor": true
  }
} 