<!DOCTYPE html>
<html>
  <head>
    <title>Budget Tracker</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Track your expenses and manage your budget effectively">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
  </head>

  <body class="bg-gray-50 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <%= link_to root_path, class: "flex items-center space-x-2" do %>
              <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
                <span class="text-white font-bold text-lg">$</span>
              </div>
              <span class="text-xl font-bold text-gray-900">Budget Tracker</span>
            <% end %>
          </div>
          
          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center space-x-4">
            <% if logged_in? %>
              <!-- Authenticated User Navigation -->
              <%= link_to "Dashboard", dashboard_path, 
                  class: "text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium #{'bg-blue-50 text-blue-600' if current_page?(dashboard_path)}" %>
              <%= link_to "Transactions", transactions_path, 
                  class: "text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium #{'bg-blue-50 text-blue-600' if current_page?(transactions_path)}" %>
              <%= link_to "Categories", categories_path, 
                  class: "text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium #{'bg-blue-50 text-blue-600' if current_page?(categories_path)}" %>
              <%= link_to "Budgets", budget_plans_path, 
                  class: "text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium #{'bg-blue-50 text-blue-600' if current_page?(budget_plans_path)}" %>
              
              <!-- Quick Add Transaction Button -->
              <%= link_to new_transaction_path, 
                  class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium flex items-center space-x-1" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                <span>Add Transaction</span>
              <% end %>
              
              <!-- User Menu Dropdown -->
              <div class="relative">
                <button data-user-menu-button class="flex items-center space-x-2 text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium">
                  <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                    <span class="text-blue-600 font-medium text-sm">
                      <%= current_user.name.split(' ').map(&:first).join.upcase %>
                    </span>
                  </div>
                  <span><%= current_user.name %></span>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                
                <!-- Dropdown Menu -->
                <div data-user-menu-dropdown class="absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 z-50 border border-gray-200 opacity-0 invisible transition-all duration-200">
                  <%= link_to user_path(current_user), 
                      class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 flex items-center space-x-2" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    <span>Profile</span>
                  <% end %>
                  
                  <div class="border-t border-gray-100"></div>
                  
                  <%= link_to logout_path, method: :delete, 
                      class: "block px-4 py-2 text-sm text-red-600 hover:bg-red-50 flex items-center space-x-2",
                      data: { 
                        turbo_method: :delete,
                        confirm: "Are you sure you want to sign out?"
                      } do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                    </svg>
                    <span>Sign Out</span>
                  <% end %>
                </div>
              </div>
            <% else %>
              <!-- Non-authenticated User Navigation -->
              <%= link_to "Sign In", login_path, 
                  class: "text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium" %>
              <%= link_to "Sign Up", signup_path, 
                  class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium" %>
            <% end %>
          </div>
          
          <!-- Mobile menu button -->
          <div class="md:hidden flex items-center">
            <button data-mobile-menu-button class="text-gray-700 hover:text-blue-600 p-2">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
          </div>
        </div>
        
        <!-- Mobile Navigation Menu -->
        <div data-mobile-menu class="md:hidden hidden border-t border-gray-200 py-4">
          <% if logged_in? %>
            <!-- Mobile User Info -->
            <div class="flex items-center space-x-3 px-4 py-3 border-b border-gray-200 mb-3">
              <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                <span class="text-blue-600 font-medium">
                  <%= current_user.name.split(' ').map(&:first).join.upcase %>
                </span>
              </div>
              <div>
                <p class="font-medium text-gray-900"><%= current_user.name %></p>
                <p class="text-sm text-gray-500"><%= current_user.email %></p>
              </div>
            </div>
            
            <!-- Mobile Navigation Links -->
            <div class="space-y-1 px-4">
              <%= link_to dashboard_path, 
                  class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50 #{'bg-blue-50 text-blue-600' if current_page?(dashboard_path)}" do %>
                <div class="flex items-center space-x-3">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"></path>
                  </svg>
                  <span>Dashboard</span>
                </div>
              <% end %>
              
              <%= link_to transactions_path, 
                  class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50 #{'bg-blue-50 text-blue-600' if current_page?(transactions_path)}" do %>
                <div class="flex items-center space-x-3">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                  </svg>
                  <span>Transactions</span>
                </div>
              <% end %>
              
              <%= link_to categories_path, 
                  class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50 #{'bg-blue-50 text-blue-600' if current_page?(categories_path)}" do %>
                <div class="flex items-center space-x-3">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                  </svg>
                  <span>Categories</span>
                </div>
              <% end %>
              
              <%= link_to budget_plans_path, 
                  class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50 #{'bg-blue-50 text-blue-600' if current_page?(budget_plans_path)}" do %>
                <div class="flex items-center space-x-3">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                  </svg>
                  <span>Budgets</span>
                </div>
              <% end %>
              
              <div class="border-t border-gray-200 mt-3 pt-3">
                <%= link_to user_path(current_user), 
                    class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50" do %>
                  <div class="flex items-center space-x-3">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    <span>Profile</span>
                  </div>
                <% end %>
                
                <%= link_to logout_path, method: :delete, 
                    class: "block px-3 py-2 rounded-md text-base font-medium text-red-600 hover:bg-red-50",
                    data: { 
                      turbo_method: :delete,
                      confirm: "Are you sure you want to sign out?"
                    } do %>
                  <div class="flex items-center space-x-3">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                    </svg>
                    <span>Sign Out</span>
                  </div>
                <% end %>
              </div>
            </div>
          <% else %>
            <!-- Mobile Non-authenticated Navigation -->
            <div class="space-y-1 px-4">
              <%= link_to "Sign In", login_path, 
                  class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50" %>
              <%= link_to "Sign Up", signup_path, 
                  class: "block px-3 py-2 rounded-md text-base font-medium bg-blue-600 text-white hover:bg-blue-700" %>
            </div>
          <% end %>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice %>
      <div data-flash-message class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 mx-4 mt-4 rounded-md flex items-center space-x-2" role="alert">
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span><%= notice %></span>
      </div>
    <% end %>
    
    <% if alert %>
      <div data-flash-message class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 mx-4 mt-4 rounded-md flex items-center space-x-2" role="alert">
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16c-.77.833.192 2.5 1.732 2.5z"></path>
        </svg>
        <span><%= alert %></span>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
      <%= yield %>
    </main>
    
    <!-- Floating Action Button (Mobile Only) -->
    <% if logged_in? %>
      <%= link_to new_transaction_path, 
          class: "md:hidden fixed bottom-6 right-6 bg-blue-600 hover:bg-blue-700 text-white p-4 rounded-full shadow-lg transition-all duration-200 hover:shadow-xl z-40",
          title: "Add Transaction" do %>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
      <% end %>
    <% end %>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-auto">
      <div class="max-w-7xl mx-auto py-4 px-4 sm:px-6 lg:px-8">
        <div class="text-center text-gray-500 text-sm">
          Built with ❤️ using Rails 8 & Tailwind CSS
          <% if logged_in? %>
            <span class="mx-2">•</span>
            <span>Welcome, <%= current_user.name %>!</span>
          <% end %>
        </div>
      </div>
    </footer>
  </body>
</html>
