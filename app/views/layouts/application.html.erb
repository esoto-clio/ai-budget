<!DOCTYPE html>
<html>
  <head>
    <title>Budget Tracker</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Track your expenses and manage your budget effectively">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
  </head>

  <body class="bg-gray-50 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <%= link_to root_path, class: "flex items-center space-x-2" do %>
              <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
                <span class="text-white font-bold text-lg">$</span>
              </div>
              <span class="text-xl font-bold text-gray-900">Budget Tracker</span>
            <% end %>
          </div>
          
          <div class="flex items-center space-x-4">
            <%= link_to "Dashboard", root_path, 
                class: "text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium #{'bg-blue-50 text-blue-600' if current_page?(root_path)}" %>
            <%= link_to "Transactions", transactions_path, 
                class: "text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium #{'bg-blue-50 text-blue-600' if current_page?(transactions_path)}" %>
            <%= link_to "Categories", categories_path, 
                class: "text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium #{'bg-blue-50 text-blue-600' if current_page?(categories_path)}" %>
            <%= link_to "Budgets", budget_plans_path, 
                class: "text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium #{'bg-blue-50 text-blue-600' if current_page?(budget_plans_path)}" %>
            
            <!-- Quick Add Transaction Button -->
            <%= link_to new_transaction_path, 
                class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium flex items-center space-x-1" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
              </svg>
              <span>Add Transaction</span>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 mx-4 mt-4 rounded-md" role="alert">
        <%= notice %>
      </div>
    <% end %>
    
    <% if alert %>
      <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 mx-4 mt-4 rounded-md" role="alert">
        <%= alert %>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-auto">
      <div class="max-w-7xl mx-auto py-4 px-4 sm:px-6 lg:px-8">
        <div class="text-center text-gray-500 text-sm">
          Built with ❤️ using Rails 8 & Tailwind CSS
        </div>
      </div>
    </footer>
  </body>
</html>
