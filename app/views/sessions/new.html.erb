<div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 flex items-center justify-center px-4">
  <div class="max-w-md w-full space-y-8">
    <!-- Header -->
    <div class="text-center">
      <div class="mx-auto h-16 w-16 bg-blue-600 rounded-xl flex items-center justify-center mb-4">
        <span class="text-white text-2xl font-bold">$</span>
      </div>
      <h1 class="text-3xl font-bold text-gray-900">Welcome Back</h1>
      <p class="text-gray-600 mt-2">Sign in to your Budget Tracker account</p>
    </div>

    <!-- Login Form -->
    <div class="bg-white rounded-lg shadow-lg p-8">
      <%= form_with(scope: :session, url: login_path, local: true, class: "space-y-6") do |form| %>
        
        <!-- Email Field -->
        <div>
          <%= form.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.email_field :email, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
              placeholder: "Enter your email",
              required: true,
              autocomplete: "email" %>
        </div>

        <!-- Password Field -->
        <div>
          <%= form.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.password_field :password, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
              placeholder: "Enter your password",
              required: true,
              autocomplete: "current-password" %>
        </div>

        <!-- Security Notice -->
        <div class="bg-blue-50 border border-blue-200 rounded-md p-3">
          <div class="flex">
            <svg class="w-5 h-5 text-blue-400 mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
            </svg>
            <div class="text-sm">
              <p class="text-blue-700">🔒 Your login is protected by:</p>
              <ul class="text-blue-600 text-xs mt-1 space-y-1">
                <li>• Rate limiting (5 attempts max)</li>
                <li>• Secure session management</li>
                <li>• Encrypted password verification</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Submit Button -->
        <%= form.submit "Sign In", 
            class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors cursor-pointer" %>
      <% end %>

      <!-- Links -->
      <div class="text-center mt-6 space-y-2">
        <p class="text-sm text-gray-600">
          Don't have an account? 
          <%= link_to "Create one here", signup_path, class: "text-blue-600 hover:text-blue-500 font-medium" %>
        </p>
        <p class="text-xs text-gray-500">
          <%= link_to "← Back to Home", root_path, class: "text-gray-400 hover:text-gray-600" %>
        </p>
      </div>
    </div>

    <!-- Security Features -->
    <div class="text-center text-xs text-gray-500">
      <p>🛡️ Protected by enterprise-grade security</p>
    </div>
  </div>
</div>
